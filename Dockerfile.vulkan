# Build stage
FROM ubuntu:22.04 AS builder

ENV DEBIAN_FRONTEND=noninteractive

# Install pre-requisites
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    cmake \
    git \
    wget \
    ca-certificates \
    gnupg \
    && rm -rf /var/lib/apt/lists/*

# Add LunarG Vulkan SDK repository and install vulkan-sdk
RUN wget -qO- https://packages.lunarg.com/lunarg-signing-key-pub.asc | tee /etc/apt/trusted.gpg.d/lunarg.asc \
    && wget -qO /etc/apt/sources.list.d/lunarg-vulkan-jammy.list http://packages.lunarg.com/vulkan/lunarg-vulkan-jammy.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends vulkan-sdk glslang-tools \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy the source code
COPY . .

# 1) Build GGML with Vulkan support
RUN cmake -S ggml -B ggml/build -DGGML_VULKAN=ON
RUN cmake --build ggml/build -j$(nproc)

# 2) Build qwen3-tts.cpp
RUN cmake -S . -B build -DQWEN3_TTS_TIMING=ON
RUN cmake --build build -j$(nproc)

# Runtime stage
FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# Install runtime dependencies: Vulkan loader, vulkan-tools, mesa-vulkan-drivers, libgomp1, python3, pip, and OpenGL/X11 libraries for NVIDIA
RUN apt-get update && apt-get install -y --no-install-recommends \
    wget \
    ca-certificates \
    gnupg \
    && wget -qO- https://packages.lunarg.com/lunarg-signing-key-pub.asc | tee /etc/apt/trusted.gpg.d/lunarg.asc \
    && wget -qO /etc/apt/sources.list.d/lunarg-vulkan-jammy.list http://packages.lunarg.com/vulkan/lunarg-vulkan-jammy.list \
    && apt-get update && apt-get install -y --no-install-recommends \
    libvulkan1 \
    vulkan-tools \
    mesa-vulkan-drivers \
    libgomp1 \
    python3 \
    python3-pip \
    python3-setuptools \
    libxext6 \
    libegl1 \
    libglvnd0 \
    libgl1 \
    libglx0 \
    libxcb-glx0 \
    libx11-6 \
    && apt-get purge -y wget gnupg \
    && apt-get autoremove -y \
    && rm -rf /var/lib/apt/lists/*

RUN pip3 install --no-cache-dir fastapi uvicorn websockets numpy

# Environment variables for NVIDIA Container Toolkit - Exclude NVIDIA GPUs
ENV NVIDIA_VISIBLE_DEVICES=none

WORKDIR /app

# Copy compiled binaries and libraries from builder
COPY --from=builder /app/build/qwen3-tts-cli /app/
COPY --from=builder /app/build/libqwen3tts.so* /usr/local/lib/
COPY --from=builder /app/ggml/build/src/libggml*.so* /usr/local/lib/
COPY --from=builder /app/ggml/build/src/ggml-vulkan/libggml-vulkan.so* /usr/local/lib/

# Copy python wrapper and API server
COPY qwen3_tts_vulkan.py /app/
COPY app_vulkan.py /app/

RUN ldconfig

# Entrypoint to run FastAPI server
ENTRYPOINT ["uvicorn", "app_vulkan:app", "--host", "0.0.0.0", "--port", "8090"]
